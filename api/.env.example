# ============================================================
#  LyraNote API — Environment Variables
#  Copy to .env and fill in your values
# ============================================================
#
#  ⚠️  以下变量是启动所需的基础设施配置，只能通过 .env 设置。
#  AI 密钥、存储、人格等运行时配置已迁移到数据库 (app_config 表)，
#  通过 Setup Wizard 或设置页面管理，无需在此配置。
#
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lyranote:lyranote@localhost:5433/lyranote

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (Local JWT) ────────────────────────────────────────
# Generate: openssl rand -hex 32
# Leave empty in dev = random per-process (sessions lost on restart)
JWT_SECRET=
JWT_EXPIRE_DAYS=30

# ── OAuth — Google ───────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
#   {APP_BASE_URL}{API_PREFIX}/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ───────────────────────────────────────────
# https://github.com/settings/applications/new
# Authorization callback URL:
#   {APP_BASE_URL}{API_PREFIX}/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── URL Config ───────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ── Memory Layer ─────────────────────────────────────────────
# File storage dir; empty = ~/.lyranote/memory (default)
# MEMORY_DIR=./data/memory
# Mode: "server" (DB-only injection) | "desktop" (file ↔ DB sync)
MEMORY_MODE=server

# ── App ──────────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ============================================================
#  以下配置已迁移到数据库，通过 UI (Setup Wizard / 设置页面) 管理。
#  如果在 .env 中设置，仅作为数据库无值时的 fallback 默认值。
#
#  · AI / LLM:     OPENAI_API_KEY, OPENAI_BASE_URL, LLM_MODEL,
#                  EMBEDDING_MODEL
#  · 搜索:         TAVILY_API_KEY, PERPLEXITY_API_KEY
#  · 存储:         STORAGE_BACKEND, STORAGE_S3_ENDPOINT_URL,
#                  STORAGE_S3_BUCKET, STORAGE_S3_ACCESS_KEY,
#                  STORAGE_S3_SECRET_KEY
#  · AI 人格:      AI_NAME, USER_OCCUPATION, USER_PREFERENCES,
#                  CUSTOM_SYSTEM_PROMPT
#  · 邮件通知:     NOTIFY_EMAIL, SMTP_HOST, SMTP_PORT,
#                  SMTP_USERNAME, SMTP_PASSWORD, SMTP_FROM
# ============================================================
