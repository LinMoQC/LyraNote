#!/usr/bin/env bash
# lyra — LyraNote 项目 CLI
# 用法：./lyra [命令]
#
# 安装后直接在项目根目录运行：
#   ./lyra          交互式菜单
#   ./lyra start    Docker 模式启动
#   ./lyra dev      本地开发模式
#   ./lyra stop     停止服务
#   ./lyra logs     查看日志
#   ./lyra status   服务状态
#   ./lyra build    重新构建镜像
#   ./lyra ps       容器列表
#   ./lyra shell    进入 API 容器 shell
#   ./lyra migrate  手动执行数据库迁移
#   ./lyra lint     前端类型检查

set -e
LYRA_ROOT="$(cd "$(dirname "$0")" && pwd)"
LYRA_SCRIPTS="$LYRA_ROOT/scripts"

# ── 颜色 ──────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

log()   { echo -e "${GREEN}✔${NC}  $*"; }
warn()  { echo -e "${YELLOW}⚠${NC}  $*"; }
error() { echo -e "${RED}✘${NC}  $*"; exit 1; }
info()  { echo -e "${CYAN}›${NC}  $*"; }

# ── 子命令 ────────────────────────────────────────────────────────────────────

cmd_help() {
  echo ""
  echo -e "  ${BOLD}lyra${NC} — LyraNote 项目 CLI"
  echo ""
  echo -e "  ${BOLD}用法：${NC}./lyra [命令] [选项]"
  echo ""
  echo -e "  ${BOLD}${GREEN}启动 / 停止${NC}"
  echo -e "    ${CYAN}start${NC}      Docker Compose 模式启动（默认）"
  echo -e "    ${CYAN}dev${NC}        本地开发模式（应用层本地 + 数据层 Docker）"
  echo -e "    ${CYAN}prod${NC}       生产模式启动（使用 ghcr.io 云端镜像）"
  echo -e "    ${CYAN}stop${NC}       停止服务"
  echo -e "    ${CYAN}restart${NC}    重启所有容器"
  echo ""
  echo -e "  ${BOLD}${GREEN}生产运维${NC}"
  echo -e "    ${CYAN}init${NC}       交互式初始化向导（生成 .env 配置文件）"
  echo -e "    ${CYAN}prod${NC}       生产模式启动（ghcr.io 云端镜像）"
  echo -e "    ${CYAN}update${NC}     git pull + 拉新镜像 + 重启（一键更新）"
  echo -e "    ${CYAN}reset${NC}      清除所有数据并重建（${RED}不可恢复${NC}）"
  echo ""
  echo -e "  ${BOLD}${GREEN}开发工具${NC}"
  echo -e "    ${CYAN}logs${NC} [svc]  查看日志（可选：api/worker/web/db/redis）"
  echo -e "    ${CYAN}status${NC}      服务状态总览"
  echo -e "    ${CYAN}ps${NC}          容器列表"
  echo -e "    ${CYAN}build${NC}       重新构建镜像"
  echo -e "    ${CYAN}shell${NC} [svc] 进入容器 shell（默认：api）"
  echo -e "    ${CYAN}migrate${NC}     执行数据库迁移"
  echo -e "    ${CYAN}lint${NC}        前端 TypeScript 类型检查"
  echo ""
  echo -e "  ${BOLD}${GREEN}其他${NC}"
  echo -e "    ${CYAN}version${NC}     显示版本信息"
  echo -e "    ${CYAN}help${NC}        显示此帮助"
  echo ""
  echo -e "  ${DIM}无参数运行 ./lyra 进入交互式菜单${NC}"
  echo ""
}

cmd_start() {
  bash "$LYRA_SCRIPTS/start.sh" docker
}

cmd_dev() {
  bash "$LYRA_SCRIPTS/start.sh" local
}

cmd_stop() {
  bash "$LYRA_SCRIPTS/start.sh" stop
}

cmd_restart() {
  info "重启所有容器..."
  cd "$LYRA_ROOT"
  docker compose restart
  log "重启完成"
}

cmd_logs() {
  local svc="${1:-}"
  cd "$LYRA_ROOT"
  if [ -n "$svc" ]; then
    docker compose logs -f --tail=100 "$svc"
  else
    bash "$LYRA_SCRIPTS/start.sh" logs
  fi
}

cmd_status() {
  bash "$LYRA_SCRIPTS/start.sh" status
}

cmd_ps() {
  cd "$LYRA_ROOT"
  docker compose ps
}

cmd_build() {
  bash "$LYRA_SCRIPTS/start.sh" build
}

cmd_shell() {
  local svc="${1:-api}"
  cd "$LYRA_ROOT"
  info "进入 ${svc} 容器..."
  docker compose exec "$svc" /bin/bash 2>/dev/null || \
  docker compose exec "$svc" /bin/sh
}

cmd_migrate() {
  info "执行数据库迁移..."
  cd "$LYRA_ROOT"
  if docker compose ps api 2>/dev/null | grep -q "running"; then
    docker compose exec api alembic upgrade head
  else
    warn "API 容器未运行，尝试本地执行..."
    source "$LYRA_ROOT/api/.venv/bin/activate" 2>/dev/null || \
      error "虚拟环境不存在，请先运行 ./lyra dev"
    cd "$LYRA_ROOT/api"
    alembic upgrade head
  fi
  log "迁移完成"
}

cmd_prod() {
  info "生产模式启动（ghcr.io 云端镜像）..."
  cd "$LYRA_ROOT"
  if [ ! -f ".env" ]; then
    warn ".env 不存在，从 .env.example 复制..."
    cp ".env.example" ".env"
    warn "请先编辑 ${BOLD}.env${NC} 填入生产环境配置后重新运行。"
    "${EDITOR:-vi}" ".env"
  fi
  docker compose -f docker-compose.prod.yml pull
  docker compose -f docker-compose.prod.yml up -d
  log "生产环境已启动"
}

cmd_update() {
  info "更新到最新版本..."
  cd "$LYRA_ROOT"
  git pull
  docker compose -f docker-compose.prod.yml pull web api worker
  docker compose -f docker-compose.prod.yml up -d
  docker image prune -f
  log "更新完成"
}

cmd_reset() {
  cd "$LYRA_ROOT"
  echo ""
  echo -e "  ${RED}${BOLD}⚠  警告：此操作将删除所有容器和数据（不可恢复）${NC}"
  echo ""
  read -rp "  输入 'yes' 确认: " confirm
  if [ "$confirm" = "yes" ]; then
    docker compose -f docker-compose.prod.yml down -v --remove-orphans 2>/dev/null || \
    docker compose down -v --remove-orphans
    log "已清除所有容器和数据"
    read -rp "  立即重新启动？[Y/n] " ans
    if [[ "${ans:-y}" =~ ^[Yy]$ ]]; then
      cmd_prod
    fi
  else
    info "已取消"
  fi
}

# ── 颜色输入提示 ──────────────────────────────────────────────────────────────
_ask() {
  # _ask "提示文字" "默认值（可空）" → 输出到 REPLY
  local prompt="$1" default="$2"
  if [ -n "$default" ]; then
    read -rp "$(echo -e "  ${CYAN}?${NC} $prompt ${DIM}[$default]${NC}: ")" REPLY
    REPLY="${REPLY:-$default}"
  else
    read -rp "$(echo -e "  ${CYAN}?${NC} $prompt: ")" REPLY
  fi
}

_ask_secret() {
  local prompt="$1"
  read -rsp "$(echo -e "  ${CYAN}?${NC} $prompt ${DIM}(输入不显示)${NC}: ")" REPLY
  echo ""
}

_ask_yn() {
  local prompt="$1" default="${2:-y}"
  read -rp "$(echo -e "  ${CYAN}?${NC} $prompt ${DIM}[${default}]${NC}: ")" REPLY
  REPLY="${REPLY:-$default}"
  [[ "$REPLY" =~ ^[Yy]$ ]]
}

cmd_init() {
  cd "$LYRA_ROOT"
  echo ""
  echo -e "  ${BOLD}${CYAN}LyraNote 初始化向导${NC}"
  echo -e "  ${DIM}引导你完成环境变量配置，按 Enter 使用默认值${NC}"
  echo ""

  # ── 部署模式 ────────────────────────────────────────────────────────────────
  echo -e "  ${BOLD}▸ 部署模式${NC}"
  echo -e "    ${BOLD}1${NC}  本地开发  ${DIM}(localhost)${NC}"
  echo -e "    ${BOLD}2${NC}  生产服务器 ${DIM}(自定义域名)${NC}"
  read -rp "$(echo -e "  ${CYAN}?${NC} 选择模式 ${DIM}[1]${NC}: ")" mode_choice
  mode_choice="${mode_choice:-1}"
  echo ""

  if [ "$mode_choice" = "2" ]; then
    # ── 生产模式：根目录 .env ──────────────────────────────────────────────
    echo -e "  ${BOLD}▸ 域名配置${NC}"
    _ask "前端域名 (e.g. https://lyra.example.com)" "https://your-domain.com"
    local frontend_url="$REPLY"
    _ask "API 域名 (e.g. https://api.example.com，留空与前端相同)" ""
    local app_base_url="${REPLY:-$frontend_url}"

    echo ""
    echo -e "  ${BOLD}▸ 数据库密码${NC}"
    _ask_secret "PostgreSQL 密码"
    local pg_pass="$REPLY"
    [ -z "$pg_pass" ] && pg_pass="$(openssl rand -hex 16 2>/dev/null || echo "lyranote_$(date +%s)")"

    echo ""
    echo -e "  ${BOLD}▸ MinIO 密码${NC}"
    _ask_secret "MinIO 密码（留空自动生成）"
    local minio_pass="$REPLY"
    [ -z "$minio_pass" ] && minio_pass="$(openssl rand -hex 16 2>/dev/null || echo "minio_$(date +%s)")"

    # 写入根目录 .env
    cat > "$LYRA_ROOT/.env" <<EOF
# 由 ./lyra init 生成 $(date)

POSTGRES_PASSWORD=$pg_pass
MINIO_ROOT_USER=lyranote
MINIO_ROOT_PASSWORD=$minio_pass
APP_BASE_URL=$app_base_url
FRONTEND_URL=$frontend_url
CORS_ORIGINS=$frontend_url
EOF
    log "生产环境变量已写入 ${BOLD}.env${NC}"
  fi

  # ── api/.env ──────────────────────────────────────────────────────────────
  echo ""
  echo -e "  ${BOLD}▸ JWT 密钥${NC}"
  local jwt_secret
  jwt_secret="$(openssl rand -hex 32 2>/dev/null || date +%s%N | sha256sum | cut -c1-64)"
  echo -e "  ${DIM}自动生成 JWT_SECRET: ${jwt_secret:0:16}...${NC}"

  echo ""
  echo -e "  ${BOLD}▸ OAuth 登录（可选，直接回车跳过）${NC}"
  _ask "Google Client ID" ""
  local google_id="$REPLY"
  _ask_secret "Google Client Secret"
  local google_secret="$REPLY"
  _ask "GitHub Client ID" ""
  local github_id="$REPLY"
  _ask_secret "GitHub Client Secret"
  local github_secret="$REPLY"

  # 确定 api/.env 的基础设施地址
  local db_url redis_url app_url frontend cors
  if [ "$mode_choice" = "2" ]; then
    # 读取刚才写入的 .env
    local pg_pass2; pg_pass2="$(grep POSTGRES_PASSWORD "$LYRA_ROOT/.env" | cut -d= -f2)"
    db_url="postgresql+asyncpg://lyranote:${pg_pass2}@db:5432/lyranote"
    redis_url="redis://redis:6379/0"
    app_url="$(grep APP_BASE_URL "$LYRA_ROOT/.env" | cut -d= -f2)"
    frontend="$(grep FRONTEND_URL "$LYRA_ROOT/.env" | cut -d= -f2)"
    cors="$frontend"
    local debug="false"
  else
    db_url="postgresql+asyncpg://lyranote:lyranote@localhost:5433/lyranote"
    redis_url="redis://localhost:6379/0"
    app_url="http://localhost:8000"
    frontend="http://localhost:3000"
    cors="http://localhost:3000"
    local debug="true"
  fi

  # 备份旧 api/.env
  if [ -f "$LYRA_ROOT/api/.env" ]; then
    cp "$LYRA_ROOT/api/.env" "$LYRA_ROOT/api/.env.bak"
    warn "已备份旧配置到 api/.env.bak"
  fi

  # 写入 api/.env
  cat > "$LYRA_ROOT/api/.env" <<EOF
# 由 ./lyra init 生成 $(date)

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=$db_url

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=$redis_url

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=$jwt_secret
JWT_EXPIRE_DAYS=30

# ── OAuth — Google ────────────────────────────────────────────
GOOGLE_CLIENT_ID=$google_id
GOOGLE_CLIENT_SECRET=$google_secret

# ── OAuth — GitHub ────────────────────────────────────────────
GITHUB_CLIENT_ID=$github_id
GITHUB_CLIENT_SECRET=$github_secret

# ── URL Config ────────────────────────────────────────────────
APP_BASE_URL=$app_url
API_PREFIX=/api/v1
FRONTEND_URL=$frontend

# ── App ───────────────────────────────────────────────────────
DEBUG=$debug
CORS_ORIGINS=$cors
MEMORY_MODE=server
EOF

  echo ""
  log "api/.env 已生成"
  echo ""
  echo -e "  ${BOLD}${GREEN}✔ 初始化完成！${NC}"
  echo ""

  if [ "$mode_choice" = "2" ]; then
    echo -e "  下一步：${CYAN}./lyra prod${NC}  启动生产环境"
  else
    echo -e "  下一步：${CYAN}./lyra start${NC}  启动开发环境"
  fi
  echo ""
}

cmd_lint() {
  info "TypeScript 类型检查..."
  cd "$LYRA_ROOT/web"
  pnpm exec tsc --noEmit && log "类型检查通过 ✓"
}

cmd_version() {
  local ver
  ver=$(cd "$LYRA_ROOT" && git describe --tags --abbrev=0 2>/dev/null || echo "dev")
  local branch
  branch=$(cd "$LYRA_ROOT" && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
  local commit
  commit=$(cd "$LYRA_ROOT" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  echo ""
  echo -e "  ${BOLD}LyraNote${NC}"
  echo -e "  版本   ${CYAN}$ver${NC}"
  echo -e "  分支   ${DIM}$branch${NC}"
  echo -e "  提交   ${DIM}$commit${NC}"
  echo ""
}

# ── 入口 ──────────────────────────────────────────────────────────────────────

case "${1:-}" in
  "")         bash "$LYRA_SCRIPTS/start.sh" ;;
  start)      cmd_start ;;
  dev)        cmd_dev ;;
  stop)       cmd_stop ;;
  restart)    cmd_restart ;;
  logs)       cmd_logs "${2:-}" ;;
  status)     cmd_status ;;
  ps)         cmd_ps ;;
  build)      cmd_build ;;
  shell)      cmd_shell "${2:-api}" ;;
  migrate)    cmd_migrate ;;
  lint)       cmd_lint ;;
  version|-v) cmd_version ;;
  help|-h|--help) cmd_help ;;
  prod)       cmd_prod ;;
  update)     cmd_update ;;
  reset)      cmd_reset ;;
  init)       cmd_init ;;
  *)
    warn "未知命令：$1"
    cmd_help
    exit 1
    ;;
esac
