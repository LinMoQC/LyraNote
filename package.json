{
  "name": "lyranote",
  "version": "1.0.0",
  "type": "module",
  "description": "<div align=\"center\">   <img width=\"120\" alt=\"LyraNote Logo\" src=\"./web/public/lyra.png\">",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lyra": "./lyra",
    "start": "./lyra start",
    "dev": "./lyra dev",
    "stop": "./lyra stop",
    "logs": "./lyra logs",
    "status": "./lyra status",
    "typecheck": "cd web && pnpm exec tsc --noEmit",
    "docs:dev": "cd docs-site && pnpm run dev",
    "docs:build": "cd docs-site && pnpm run build",
    "docs:preview": "cd docs-site && pnpm run preview"
  },
  "repository": {
    "type": "git",
    "url": "git@github-linmoqc:LinMoQC/LyraNote.git"
  },
  "lint-staged": {
    "web/src/**/*.{ts,tsx}": [
      "bash -c 'cd web && pnpm exec tsc --noEmit'"
    ]
  },
  "keywords": [],
