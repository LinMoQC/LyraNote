# ============================================================
#  LyraNote Web — Environment Variables
#  Copy to .env.local and fill in your values
# ============================================================

# FastAPI backend URL (client-side, baked at build time)
# Dev:  http://localhost:8000/api/v1
# Prod: /api/v1  (relative, via nginx reverse proxy)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
