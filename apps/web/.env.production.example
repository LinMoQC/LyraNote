# 复制为 .env.production.local 或 .env.prod 后执行 pnpm build
#
# ── 推荐：API 独立域名/端口（与前端不同源）──────────────────────────────────────
# NEXT_PUBLIC_* 会打进浏览器包，必须写成公网可访问的 API 根路径。
# 与仓库根 .env 中 APP_BASE_URL + /api/v1 保持一致（示例见 lyra init）
NEXT_PUBLIC_API_BASE_URL=https://YOUR_API_HOST/api/v1
# 仅本地 next start + 本机 API 时用；Docker 内由 docker-compose 注入 http://api:8000/api/v1
INTERNAL_API_BASE_URL=http://127.0.0.1:8000/api/v1
#
# ── 可选：同域 + Nginx 只暴露一个域名，/api 反代到后端 ───────────────────────
# NEXT_PUBLIC_API_BASE_URL=/api/v1
# INTERNAL_API_BASE_URL=http://127.0.0.1:8000/api/v1
